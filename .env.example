# DeepStream-VLM Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# HuggingFace token (optional, for BF16 model download)
HF_TOKEN=your_huggingface_token_here

# Display (for GUI output, optional)
DISPLAY=${DISPLAY}

# NOTE: NGC_API_KEY is entered interactively inside the container via `ngc config set`.
# It does not need to be set here.
